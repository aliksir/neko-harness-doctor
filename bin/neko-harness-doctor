#!/usr/bin/env node
// neko-harness-doctor CLI entry point
// Delegates to src/audit.mjs

import { fileURLToPath, pathToFileURL } from 'url';
import { dirname, resolve } from 'path';

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);
const auditPath = resolve(__dirname, '..', 'src', 'audit.mjs');

// Dynamic import to run the CLI with current argv.
// Windows ESM requires file:// URL for absolute paths — a raw `C:\...` path
// fails with ERR_UNSUPPORTED_ESM_URL_SCHEME because `c:` is parsed as a protocol.
await import(pathToFileURL(auditPath).href);
